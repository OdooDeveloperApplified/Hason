<odoo>
    <record id="ir_cron_fetch_indiamart_leads" model="ir.cron">
        <field name="name">Fetch IndiaMART Leads (Hourly)</field>
        <field name="model_id" ref="model_indiamart_config_settings"/>
        <field name="state">code</field>
        <field name="code">model.search([], limit=1).fetch_indiamart_leads()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
