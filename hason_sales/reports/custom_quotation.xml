<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Document Layout template -->
    <template id="document_layout_custom_quotation" >
        <t t-call="web.basic_layout">
            <!-- HEADER -->
            <!-- HEADER -->
            <div style="border:1px solid black; padding:5px; width:100%;">

                <!-- Company Name -->
                <div style="text-align:center; font-size:30px; font-weight:bold;">
                    <span t-esc="res_company.name"/>
                </div>

                <!-- Address -->
                <div style="text-align:center; font-size:16px;">
                    <t t-if="res_company.street">
                        <span t-esc="res_company.street"/>
                    </t>
                    <t t-if="res_company.street2">
                        <span t-esc="res_company.street2"/><br/>
                    </t>
                    <t t-if="res_company.city">
                        <span t-esc="res_company.city"/>,
                    </t>
                    <t t-if="res_company.state_id">
                        <span t-esc="res_company.state_id.name"/>
                    </t>
                    <t t-if="res_company.country_id">
                        (<span t-esc="res_company.country_id.name"/>)
                    </t>
                    <t t-if="res_company.zip">
                        - <span t-esc="res_company.zip"/>
                    </t>
                </div>

                <!-- GST Row -->
                <div style="margin-top:8px; font-size:16px; width:100%;">
                    <div style="float:left;">
                        <b>VAT TIN No:</b>
                        <span t-esc="res_company.vat"/>
                    </div>

                    <div style="float:right;">
                        <b>CST TIN No:</b> 24580801383
                    </div>

                    <div style="clear:both;"></div>
                </div>

            </div>

            <!-- Inner content -->
            <div>
                <t t-out="0"/>
            </div>
        </t>
    </template>

    <!-- Report content section (Inner content) -->
    <template id="custom_quotation_report_views">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="hason_sales.document_layout_custom_quotation">
                    <div class="page" style="font-size: 16px; overflow: hidden;">
                       
                        <div class="row mt-2" style="border:1px solid black;">
                            <div class="col-12 text-center">
                                <span style="font-size:20px; font-weight:bold; margin-top:3px; margin-bottom:3px;"> QUOTATION </span>
                            </div>
                        </div>

                        <!-- Address block -->
                        <div class="mt-2" style="width:100%; border:1px solid black;">
                            <!-- Left Column -->
                            <div style="display:inline-block; vertical-align:top; width:49%; border-right:1px solid black; box-sizing:border-box; padding-left:6px; padding-top:4px; padding-bottom:4px;">
                                <span><strong>Name: </strong><t t-esc="doc.partner_id.name"/></span><br/>
                                <span><strong>Address: </strong><t t-esc="doc.partner_id.street"/></span><br/>
                                <t t-esc="doc.partner_id.street2"/><br/>
                                <t t-esc="doc.partner_id.city"/><br/>
                                <span><strong>State: </strong><t t-esc="doc.partner_id.state_id.name"/></span><br/>
                                <span><strong>GSTIN No. : </strong><t t-esc="doc.partner_id.vat"/></span><br/>
                                <span><strong>PAN No. : </strong><t t-esc="doc.partner_id.l10n_in_pan"/></span><br/>
                            </div>
                            <!-- Right Column -->
                            <div style="display:inline-block; vertical-align:top; width:49%; box-sizing:border-box; padding-left:6px; padding-top:4px; padding-bottom:4px;">
                                <span><strong>Quotation No.: </strong><t t-esc="doc.name"/></span><br/>
                                <span><strong>Quotation Date: </strong><t t-esc="doc.create_date" t-options='{"widget": "date"}'/></span><br/>
                            </div>
                        </div>
                    
                        <div>
                            <div class="row mb-1" style="text-align: center; vertical-align: middle;"/>
                            <!-- Count only real product lines -->
                            <t t-set="real_lines" t-value="[line for line in doc.order_line if not line.display_type]"/>
                            <t t-set="last_index" t-value="len(real_lines)"/>
                            <t t-set="counter" t-value="0"/>
                            <table class="table table-bordered" style="background-color: white; width: 100%; border: 1px solid black; font-size: 16px;">
                                <t t-set="total_amount" t-value="0"/>
                                <thead>
                                    <tr style="text-align: center;">
                                        <th style="font-weight:bold;">Sr.</th>
                                        <th style="width: 40%;text-align: center;font-weight:bold;">Particular</th>
                                        <th style="width: 14%;text-align: center;font-weight:bold;">HSN / SAC</th>
                                        <th style="width: 10%;text-align: center;font-weight:bold;">Quantity</th>
                                        <th style="width: 18%;text-align: center;font-weight:bold;">Rate</th>
                                        <th style="width: 18%;text-align: center;font-weight:bold;">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.order_line" t-as="line">
                                        <t t-if="line.display_type == 'line_note'">
                                            <tr >
                                                <td colspan="99" style="font-style: italic;text-align: left; background-color: #f7f7f7;">
                                                    <span t-field="line.name"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-elif="line.display_type == 'line_section'">
                                            <tr style="border: 1px solid black;">
                                                <td colspan="99" style="font-style: italic; text-align: left; background-color: #f7f7f7;">
                                                    <span t-field="line.name"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <!-- Normal Product Line -->
                                        <t t-elif="not line.display_type">
                                            <t t-set="counter" t-value="counter + 1"/>
                                            <t t-set="total_amount" t-value="total_amount + (line.price_subtotal or 0)"/>
                                            <tr>
                                                <!-- SR NO -->
                                                <td style="text-align:center;">
                                                    <t t-esc="counter"/>
                                                </td>

                                                <!-- PARTICULARS -->
                                                <td style="text-align: center;">
                                                    <!-- Product Name -->
                                                    <span t-if="line.product_id" t-esc="line.product_id.name"/><br/>
                                                    <!-- Product Description -->
                                                    <span t-if="line.name" t-esc="line.name"/><br/>
                                                </td>

                                                <!-- HSN/SAC CODE -->
                                                <td style="text-align: center;">
                                                    <span t-if="line.product_id.l10n_in_hsn_code" t-esc="line.product_id.l10n_in_hsn_code"/>
                                                </td>
                                                
                                                <!-- QUANTITY -->
                                                <td style="text-align: center;">
                                                    <span t-field="line.product_uom_qty"/>
                                                </td>
                                                
                                                <!-- RATE -->
                                                <td style="text-align:center;">
                                                    <span t-field="line.price_unit"
                                                        t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                                </td>
                                                <!-- AMOUNT -->
                                                <td style="text-align:right;">
                                                    <span t-field="line.price_subtotal"
                                                        t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                    <!-- SUB TOTAL ROW -->
                                    <tr>
                                        <!-- LEFT INFO BLOCK -->
                                        <td colspan="4" style="vertical-align:top; padding:8px;">
                                            <b>Transport :</b>
                                            <span t-esc="doc.transport"/><br/>
                                            <b>Payment Terms:</b>
                                            <span t-if="doc.payment_term_id" t-esc="doc.payment_term_id.name"/>
                                        </td>
                                        <!-- RIGHT TAX TABLE -->
                                        <td colspan="2" style="padding:0;">
                                            <table style="width:100%; border-collapse:collapse; font-size:16px;">
                                                <tr style="font-weight:bold;">
                                                    <td style="padding:6px;">Sub Total</td>
                                                    <td style="text-align:right;padding:6px;">
                                                        <span t-esc="doc.amount_total"
                                                            t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                                    </td>
                                                </tr>
                                                <tr style="font-weight:bold;">
                                                    <td style="padding:6px;">Grand Total (Rounded)</td>
                                                    <td style="text-align:right;padding:6px;">
                                                        <span t-esc="doc.amount_total_rounded"
                                                            t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>  
                                </tbody>
                            </table>
                        </div>
                        <t t-set="amount_for_words" t-value="doc.amount_total_rounded if (doc.amount_total_rounded and doc.amount_total_rounded != doc.amount_total) else doc.amount_total"/>
                        <div class="row" style="border:1px solid black; padding:5px; page-break-inside:avoid;">
                            <t t-if="amount_for_words">
                                <span style="font-weight:bold;">
                                    Invoice Value (In Words) :
                                </span>
                                <span t-esc="doc.currency_id.amount_to_text(amount_for_words) + ' Only'"/>
                            </t>
                        </div>
                    
                        <div class="row mt-2" style="page-break-inside:avoid; border:1px solid black;">
                            <div class="col-6 ms-2">
                                <span t-field="doc.note" t-attf-style="#{'text-align:justify;text-justify:inter-word;' if doc.company_id.terms_type != 'html' else ''}" name="order_note"/>
                                <p t-if="not is_html_empty(doc.payment_term_id.note)"/>
                                <div class="oe_structure"/> 
                            </div>
                            <div class="col-1"/>
                            <div class="col-5 text-end p-4" >
                                <strong>For, HASON CHEMTECH PVT. LTD.</strong>
                                <div style="height:70px;"></div>
                                <p style="font-size:18px;"><strong>Authorized Signatory </strong></p>
                            </div>
                        </div>  
                    </div>
                </t>
            </t>
        </t> 
    </template>

    <!-- Code to set desried paper format for Sale order -->
    <record id="paperformat_custom_quotation" model="report.paperformat">
        <field name="name">Quotation</field>
        <field name="default" eval="True" />
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">4</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="custom_quotation_report" model="ir.actions.report">
        <field name="name">Hason Quotation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hason_sales.custom_quotation_report_views</field>
        <field name="report_file">hason_sales.custom_quotation_report_views</field>
        <field name="attachment" eval="False"/> 
        <field name="paperformat_id" ref="hason_sales.paperformat_custom_quotation"/>
        <field name="binding_model_id" ref="model_sale_order"/>
        <field name="binding_type">report</field> <!-- Shows under the "Print" button -->
        <!-- <field name="print_report_name">'Sale-Order-%s.' % (object.name or "Sale Order")</field> -->
    </record>
    
</odoo>