<odoo>
    <record id="view_product_packaging_master_form" model="ir.ui.view">
        <field name="name">product.packaging.master.form</field>
        <field name="model">product.packaging.master</field>
        <field name="arch" type="xml">
            <form string="Packaging Master">
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="contained_quantity"/>
                        <field name="uom_id"/>
                        <field name="product_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_product_packaging_master_tree" model="ir.ui.view">
        <field name="name">product.packaging.master.tree</field>
        <field name="model">product.packaging.master</field>
        <field name="arch" type="xml">
            <tree string="Packaging Master">
                <field name="name"/>
                <field name="contained_quantity"/>
                <field name="uom_id"/>
                <field name="product_ids" widget="many2many_tags"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="action_product_packaging_master" model="ir.actions.act_window">
        <field name="name">Packaging Master</field>
        <field name="res_model">product.packaging.master</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_product_packaging_master"
          name="Packaging Master"
          parent="sale.prod_config_main"
          action="action_product_packaging_master"
          sequence="30"/>
</odoo>
