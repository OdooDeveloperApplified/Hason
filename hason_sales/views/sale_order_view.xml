<odoo>

    <!-- Add transport above validity_date -->
    <record id="view_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='validity_date']" position="before">
                <field name="transport"/>
            </xpath>
            <xpath expr="//field[@name='l10n_in_gst_treatment']" position="after">
                <field name="subject"/>
            </xpath>
            <xpath expr="//field[@name='currency_id']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
             <xpath expr="//field[@name='currency_id']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="po_no"/>
                <field name="batch_no"/>
                <field name="bill_no"/>
                <field name="lr_no"/>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                
                <field name="billing_address_type" widget="radio" options="{'horizontal': true}"/>
                
                <field name="custom_billing_partner_id" 
                       invisible="billing_address_type == 'hason'" 
                       required="billing_address_type == 'other'"/>
            
            </xpath>
            <xpath expr="//field[@name='validity_date']" position="after">
                <field name="vehicle_ids"/>
                <field name="eway_bill_no"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="after">
                <field name="packaging_id"/>
                <field name="packaging_qty"/>
            </xpath>
            <xpath expr="//group[@name='sale_total']/field[@name='tax_totals']" position="after">
                <field name="is_enabled_roundoff"/>
              
                <field name="amount_total_rounded" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                
            </xpath>

        </field>
    </record>
</odoo>
